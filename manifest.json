{
  "manifest_version": 3,
  "name": "DOM Selector Copy MVP",
  "version": "1.0",
  "description": "Use querySelectorAll to extract and copy text content",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage", "sidePanel"],
  "action": {
    "default_title": "Open Selector Copy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
